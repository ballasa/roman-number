<?xml version="1.0"?>
<!DOCTYPE module PUBLIC "-//Puppy Crawl//DTD Checkstyle Configuration 1.3//EN"
"https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <!--Regole a livello di testo:-->
    <module name="FileLength">
        <property name="max" value="500"/> <!--Abbassato da 2000 a 500: le classi devono essere piccole.-->
    </module>
    <module name="FileTabCharacter"/>
    <module name="LineLength">
        <property name="max" value="100"/> <!--Massimo 100 caratteri per riga.-->
    </module>

    <!--Header:-->
    <module name="Header">
        <property name="header" value="////////////////////////////////////////////////////////////////////\n// SARA BALLARDIN 2101048\n// DAVIDE LOPARCO 2101088\n////////////////////////////////////////////////////////////////////"/>
        <property name="fileExtensions" value="java"/>
    </module>

<!--Regole di programmazione:-->
    <module name="TreeWalker"> <!--Per risconoscere la sintassi Java.-->
        <!--Complessità:-->
        <module name="BooleanExpressionComplexity"/>
        <module name="CyclomaticComplexity"/>
        <module name="MethodLength">
            <property name="max" value="50"/>
        </module>

        <!--Stile e blocchi:-->
        <module name="EmptyCatchBlock"/>
        <module name="AvoidStarImport"/>
        <module name="IllegalImport"/>
        <module name="NeedBraces"/>
    </module>
</module>